WEEKLY_HOST_PORT=22081

# MySQL used by Docker Compose. Change this before a formal deployment.
MYSQL_DATABASE=weekly_report
MYSQL_ROOT_PASSWORD=weekly_report_root_123

# JWT signing secret must be at least 32 bytes. Change this before a formal deployment.
WEEKLY_JWT_SECRET=weekly-report-local-dev-secret-change-me-2026
WEEKLY_JWT_EXPIRE_MINUTES=720

# First startup creates this account if it does not exist.
WEEKLY_BOOTSTRAP_ADMIN_USERNAME=admin
WEEKLY_BOOTSTRAP_ADMIN_PASSWORD=admin123
WEEKLY_BOOTSTRAP_ADMIN_REAL_NAME=系统管理员

# DingTalk web login is optional. Redirect URI should point to:
# http(s)://<your-host>/api/auth/dingtalk/callback
WEEKLY_DINGTALK_LOGIN_ENABLED=false
WEEKLY_DINGTALK_CLIENT_ID=
WEEKLY_DINGTALK_CLIENT_SECRET=
WEEKLY_DINGTALK_REDIRECT_URI=http://182.92.251.239:22081/api/auth/dingtalk/callback
WEEKLY_FRONTEND_URL=http://182.92.251.239:22081/

# Feedback entry in the account dropdown. Fill userId to send DingTalk work notices directly.
# App credentials can stay empty here if config/.env already has DINGTALK_APP_KEY/SECRET/AGENT_ID.
WEEKLY_FEEDBACK_ENABLED=true
WEEKLY_FEEDBACK_RECIPIENT_NAME=张艺政
WEEKLY_FEEDBACK_DINGTALK_USER_IDS=
WEEKLY_FEEDBACK_DINGTALK_APP_KEY=
WEEKLY_FEEDBACK_DINGTALK_APP_SECRET=
WEEKLY_FEEDBACK_DINGTALK_AGENT_ID=
