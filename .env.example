# Docker Compose deployment settings. Copy to .env and fill every required blank value.
WEEKLY_AUTH_DEVELOPMENT_MODE=false
WEEKLY_HOST_PORT=22080
WEEKLY_REPORT_EXEMPT_SUBMITTERS=
# Private JSON overrides; prefer USERID selectors. Never commit real names or userids.
WEEKLY_REPORT_LEADER_OVERRIDES=

# MySQL used by Docker Compose. Use a deployment-specific value.
MYSQL_DATABASE=weekly_report
MYSQL_ROOT_PASSWORD=

# Production mode requires both values and rejects the local development defaults.
WEEKLY_JWT_SECRET=
WEEKLY_JWT_EXPIRE_MINUTES=720
WEEKLY_BOOTSTRAP_ADMIN_USERNAME=admin
WEEKLY_BOOTSTRAP_ADMIN_PASSWORD=
WEEKLY_BOOTSTRAP_ADMIN_REAL_NAME=系统管理员

# DingTalk web login is optional. Redirect URI should point to:
# http(s)://<your-host>/api/auth/dingtalk/callback
WEEKLY_DINGTALK_LOGIN_ENABLED=false
WEEKLY_DINGTALK_CLIENT_ID=
WEEKLY_DINGTALK_CLIENT_SECRET=
WEEKLY_DINGTALK_REDIRECT_URI=
WEEKLY_FRONTEND_URL=/

# Feedback entry in the account dropdown. Fill userId only in the untracked .env file.
WEEKLY_FEEDBACK_ENABLED=true
WEEKLY_FEEDBACK_RECIPIENT_NAME=示例接收人
WEEKLY_FEEDBACK_DINGTALK_USER_IDS=
WEEKLY_FEEDBACK_DINGTALK_APP_KEY=
WEEKLY_FEEDBACK_DINGTALK_APP_SECRET=
WEEKLY_FEEDBACK_DINGTALK_AGENT_ID=
# Keep WORK_NOTICE until an internal robot, its permission, and employee OTO sessions are verified.
WEEKLY_FEEDBACK_PERSONAL_MESSAGE_MODE=WORK_NOTICE
WEEKLY_FEEDBACK_DINGTALK_ROBOT_CODE=
WEEKLY_FEEDBACK_DINGTALK_ROBOT_SEND_URL=https://api.dingtalk.com/v1.0/robot/oToMessages/batchSend

# Sunday reminder is disabled until the roster, exemptions, template, and app visibility are verified.
WEEKLY_SUBMISSION_REMINDER_ENABLED=false
WEEKLY_SUBMISSION_REMINDER_CRON=0 0 18 * * SUN
WEEKLY_SUBMISSION_REMINDER_ZONE=Asia/Shanghai
WEEKLY_SUBMISSION_REMINDER_PROCESS_TIMEOUT_SECONDS=180

# Monday personal evaluation feedback is disabled until Codex output and DingTalk delivery are verified.
WEEKLY_EVALUATION_FEEDBACK_ENABLED=false
WEEKLY_EVALUATION_FEEDBACK_CRON=0 0 12 * * MON
WEEKLY_EVALUATION_FEEDBACK_ZONE=Asia/Shanghai
# Set the real HR contact only in the untracked deployment .env file.
WEEKLY_EVALUATION_FEEDBACK_HR_CONTACT=
