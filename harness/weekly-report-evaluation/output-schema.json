{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked"]
    },
    "week_label": {
      "type": "string",
      "pattern": "^[0-9]{4}-W[0-9]{2}$"
    },
    "manager_report_markdown": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 240
      },
      "maxItems": 20
    }
  },
  "required": [
    "status",
    "week_label",
    "manager_report_markdown",
    "warnings"
  ],
  "additionalProperties": false
}
