{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked"]
    },
    "week_label": {
      "type": "string",
      "pattern": "^[0-9]{4}-W[0-9]{2}$"
    },
    "manager_report_markdown": {
      "type": "string"
    },
    "employee_feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "userid": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "praise": {
            "type": "string",
            "minLength": 4,
            "maxLength": 400
          },
          "improvement": {
            "type": "string",
            "minLength": 4,
            "maxLength": 700
          },
          "thanks": {
            "type": "string",
            "minLength": 24,
            "maxLength": 220
          }
        },
        "required": ["userid", "praise", "improvement", "thanks"],
        "additionalProperties": false
      },
      "maxItems": 300
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 240
      },
      "maxItems": 20
    }
  },
  "required": [
    "status",
    "week_label",
    "manager_report_markdown",
    "employee_feedback",
    "warnings"
  ],
  "additionalProperties": false
}
